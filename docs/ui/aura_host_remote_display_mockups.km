{"root":{"data":{"text":"AURA Host Remote Display Mockups"},"children":[{"data":{"text":"01 Startup and support screens"},"children":[{"data":{"text":"WELCOME / FIRST RUN"},"children":[{"data":{"text":"Purpose: explain what the host needs before daily use"},"children":[]},{"data":{"text":"Display text"},"children":[{"data":{"text":"AURA Host"},"children":[]},{"data":{"text":"Start setup"},"children":[]},{"data":{"text":"Link phone"},"children":[]},{"data":{"text":"Local mode"},"children":[]}]}]},{"data":{"text":"NO INVENTORY DATA"},"children":[{"data":{"text":"Purpose: explain that the host has no cached part library yet"},"children":[]},{"data":{"text":"Display text"},"children":[{"data":{"text":"No part data"},"children":[]},{"data":{"text":"Sync from phone"},"children":[]},{"data":{"text":"Add basic data"},"children":[]},{"data":{"text":"Back"},"children":[]}]}]},{"data":{"text":"NO NODES CONFIGURED"},"children":[{"data":{"text":"Purpose: block locate actions until at least one node exists"},"children":[]},{"data":{"text":"Display text"},"children":[{"data":{"text":"No nodes found"},"children":[]},{"data":{"text":"Add node"},"children":[]},{"data":{"text":"Test link later"},"children":[]}]}]},{"data":{"text":"PHONE LINK / SYNC"},"children":[{"data":{"text":"Purpose: pair support phone and sync library/cache"},"children":[]},{"data":{"text":"Display text"},"children":[{"data":{"text":"Phone link"},"children":[]},{"data":{"text":"Pair new phone"},"children":[]},{"data":{"text":"Sync library"},"children":[]},{"data":{"text":"Last sync status"},"children":[]}]}]}]},{"data":{"text":"02 Daily locate flow"},"children":[{"data":{"text":"HOME"},"children":[{"data":{"text":"Purpose: primary daily entry screen"},"children":[]},{"data":{"text":"Display text"},"children":[{"data":{"text":"Locate parts"},"children":[]},{"data":{"text":"Inventory"},"children":[]},{"data":{"text":"Nodes"},"children":[]},{"data":{"text":"Setup"},"children":[]}]}]},{"data":{"text":"LOCATE ENTRY"},