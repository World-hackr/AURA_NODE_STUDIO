                "Bypass",
                "-File",
                "${workspaceFolder}\\..\\tools\\run_test_pio.ps1",
                "-Action",
                "ports",
                "-ProjectPath",
                ".",
                "-Environment",
                "nrf24_pin_smoke_esp32dev"
            ],
            "options": {
