    {
      "name": "cols",
      "defaultRaw": "8"
    },
    {
      "name": "rowSpacing",
      "decorator": "{ attribute: 'rowspacing' }",
      "defaultRaw": "1"
    },
    {
      "name": "colSpacing",
      "decorator": "{ attribute: 'colspacing' }",
      "defaultRaw": "1"
    },
    {
      "name": "blurLight",
      "defaultRaw": "false"
    },
    {
      "name": "animation",
      "defaultRaw": "false"
    }
  ]
}
