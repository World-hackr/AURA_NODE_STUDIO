{
  "schema": "aura.wokwi_part.v1",
  "libraryItemId": "servo_micro",
  "title": "Servo Motor",
  "wokwi": {
    "tagName": "wokwi-servo",
    "modulePath": "vendor_reference/wokwi-elements/dist/esm/servo-element.js",
    "naturalSizePx": {
      "width": 170.08,
      "height": 119.55
    },
    "allowOuterRotation": true
  },
  "pins": {
    "labels": ["GND", "V+", "PWM"],
    "anchors": [
      { "id": "GND", "x": 0, "y": 50 },
      { "id": "V+", "x": 0, "y": 59.5 },
      { "id": "PWM", "x": 0, "y": 69 }
    ]
  },
  "runtime": {
    "defaults": {
      "profileId": "servo_angle",
      "signalName": "angle",
      "targetId": "body_primary",
      "valueMin": 0,
      "valueMax": 180,
      "defaultValue": 90,
      "angleMin": 0,
      "angleMax": 180
    },
    "staticProps": {
      "horn": "single",
      "hornColor": "#d9d9d9"
    },
    "propBindings": [
      { "elementProp": "angle", "from": "defaultValue", "transform": "direct" }
    ]
  }
}
