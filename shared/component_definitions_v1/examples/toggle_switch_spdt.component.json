    "targetId": "handle_primary",
    "property": "toggle_state",
    "valueMin": 0,
    "valueMax": 1,
    "angleMin": -22,
    "angleMax": 22,
    "axis": "x",
    "distanceMin": -12,
    "distanceMax": 12,
    "originX": 0,
    "originY": 0,
    "glowX": 0,
    "glowY": 0,
    "glowRadius": 18,
    "glowBlur": 12,
    "glowColor": "#ff5a5a",
    "baseColor": "#ff5a5a",
    "opacityMin": 0.08,
    "opacityMax": 0.94,
    "blinkPeriodMs": 420,
    "blinkDutyCycle": 50,
    "pressDepth": 2.4,
    "detentCount": 2,
    "autoReset": false,
    "lightTargetSourceMode": "existingTarget",
    "helperShapeKind": "circle",
    "helperX": 0,
    "helperY": 0,
    "helperWidth": 56,
    "helperHeight": 56,
    "helperRadius": 14,
    "glowEnabled": true
  },
  "compiledBehavior": {
    "kind": "interactive",
    "entry": {
      "id": "handle_primary_snap_rotation",
      "type": "angle_to_value",
      "target": "handle_primary",
      "property": "toggle_state",
      "match": "exact",
      "range": [0, 1],
      "angleRange": [-22, 22],
      "detents": 2,
      "transformOrigin": [0, 0]
    }
