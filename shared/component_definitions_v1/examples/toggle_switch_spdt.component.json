    "profileId": "toggle_switch",
    "signalName": "toggle_state",
    "targetId": "handle_primary",
    "valueMin": 0,
    "valueMax": 1,
    "defaultValue": 1,
    "angleMin": -22,
    "angleMax": 22,
    "travelAxis": "x",
    "travelMin": -14,
    "travelMax": 14,
    "lowVisual": 0.1,
    "highVisual": 0.95,
    "detentCount": 12,
    "autoReset": false,
    "offLabel": "off",
    "onLabel": "on",
    "lightColor": "#ff5a5a"
  },
  "compiledRuntime": {
    "kind": "input",
    "entry": {
