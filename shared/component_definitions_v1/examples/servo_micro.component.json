{
  "schema": "aura.component_definition.v1",
  "metadata": {
    "name": "Servo Output",
    "description": "Behavior-ready servo example with explicit angle output metadata.",
    "tags": ["example", "runtime_profile", "servo", "output"]
  },
  "base": {
